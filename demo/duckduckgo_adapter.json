{
  "target_name": "DuckDuckGo AI Chat",
  "endpoint_url": "https://duck.ai/duckchat/v1/chat",
  "method": "POST",
  "auth_strategy": "dynamic_header",
  "auth_params": {
    "header_name": "x-vqd-hash-1",
    "discovery_method": "regex_from_page",
    "regex": "vqd=['\"]([^'\"]+)['\"]"
  },
  "request_mapping": {
    "model": "{model:-gpt-4o-mini}",
    "messages": [
      {
        "role": "{role}",
        "content": "{content}"
      }
    ],
    "canUseTools": true,
    "metadata": {
      "toolChoice": {
        "NewsSearch": false,
        "VideosSearch": false
      }
    }
  },
  "response_mapping": {
    "type": "sse",
    "chunk_path": "$.message"
  },
  "status": "VALIDATED"
}
