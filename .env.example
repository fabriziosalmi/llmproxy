# ──────────────────────────────────────────────────────────
# LLM Proxy — Environment Configuration Template
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.
# ──────────────────────────────────────────────────────────

# ── Infisical (Primary Secret Source) ────────────────────
INFISICAL_SITE_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=your-client-id
INFISICAL_CLIENT_SECRET=your-client-secret
INFISICAL_PROJECT_ID=your-project-id
INFISICAL_ENV=dev

# ── Fallback: Direct env vars (only if Infisical unavailable) ──
LLM_PROXY_MASTER_KEY=generate-a-strong-random-key-here
LLM_PROXY_API_KEYS=sk-proxy-your-key-1,sk-proxy-your-key-2
LLM_PROXY_IDENTITY_SECRET=generate-a-strong-random-secret
LLM_PROXY_FEDERATION_SECRET=generate-a-strong-random-secret
OPENAI_API_KEYS=sk-proj-...
ANTHROPIC_API_KEYS=sk-ant-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-v1-...
INFERCOM_API_KEY=
HF_TOKEN=hf_...

# ── Identity / SSO (OIDC) ─────────────────────────────────
OIDC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OIDC_MICROSOFT_CLIENT_ID=your-microsoft-app-id
OIDC_APPLE_CLIENT_ID=your-apple-service-id

# ── Observability ──────────────────────────────────────────
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ── Webhooks ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── ChatOps (Telegram) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# ── Local LLM ───────────────────────────────────────────
VLLM_MODEL_PATH=/models/SmolLM-135M
